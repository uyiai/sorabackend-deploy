# ===========================================
# Sora Backend - Deployment Configuration
# Copy this file to .env and fill in the values
# ===========================================

# ---------- Required ----------

# Django secret key (generate a unique one!)
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE-ME

# Database password
POSTGRES_PASSWORD=CHANGE-ME

# Redis password
REDIS_PASSWORD=CHANGE-ME

# Domain name (used for ALLOWED_HOSTS, CORS, etc.)
DOMAIN=example.com

# Server IP address
SERVER_IP=0.0.0.0

# ---------- Image Tags ----------

# Backend image tag (matches build profile: v1.9.0-base, v1.9.0-pro, v1.9.0-enterprise)
IMAGE_TAG=latest

# Frontend image tag (no profile suffix: v1.9.0)
FRONTEND_IMAGE_TAG=latest

# ---------- Ports ----------

# Backend API port (mapped to host)
WEB_PORT=8080

# Frontend port (mapped to host)
FRONTEND_PORT=3000

# ---------- Superuser ----------

DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=CHANGE-ME

# ---------- Health Check ----------

HEALTH_CHECK_TOKENS=CHANGE-ME-HEALTH-TOKEN

# ---------- Modules ----------

# Which modules to enable (leave empty to use image default from build profile)
# Available: video,image,music,conversation,creative_studio,referral,agents,wechat,sms,support
# ENABLED_MODULES=

# ---------- Monitoring ----------

# Sentry DSN (optional)
# SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ---------- Payments ----------

# Stripe (optional)
# STRIPE_LIVE_PUBLIC_KEY=
# STRIPE_LIVE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
STRIPE_LIVE_MODE=False

# ---------- Storage ----------

# Cloud media storage (optional, defaults to local)
USE_S3_MEDIA=False
# ALIYUN_OSS_ACCESS_KEY_ID=
# ALIYUN_OSS_ACCESS_KEY_SECRET=
# ALIYUN_OSS_BUCKET_NAME=
# ALIYUN_OSS_ENDPOINT=

# ---------- AI Providers (optional) ----------

# OpenAI
# OPENAI_API_KEY=

# Google
# GOOGLE_API_KEY=

# Anthropic
# ANTHROPIC_API_KEY=
